{
  "name": "react-tz-globepicker",
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "demo"
  ],
  "description": "Interactive 3D globe component for timezone selection with React",
  "homepage": "https://ywybase.vercel.app/",
  "author": "Marcio Merlone <mmerlone@gmail.com> (https://mmerlone.dev.br)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmerlone/react-tz-globepicker.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist",
    "prebuild": "pnpm clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:globe": "tsx scripts/update-globe-data.ts",
    "prepare": "husky install",
    "demo": "pnpm --filter ./demo dev"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "d3-drag": "^3.0.0",
    "d3-geo": "^3.1.1",
    "d3-selection": "^3.0.0",
    "hex-rgb": "^5.0.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-selection": "^3.0.11",
    "@types/geojson": "^7946.0.13",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-server": "^3.0.4",
    "@types/topojson-simplify": "^3.0.3",
    "@types/topojson-specification": "^1.0.5",
    "@types/yauzl": "^2.10.3",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "prettier": "^3.3.3",
    "topojson-server": "^3.0.1",
    "topojson-simplify": "^3.0.3",
    "tsx": "^4.7.1",
    "typescript": "^5.3.0",
    "visionscarto-world-atlas": "^1.0.0",
    "yauzl": "^3.2.1",
    "husky": "^8.0.0"
  },
  "keywords": [
    "react",
    "timezone",
    "globe",
    "3d",
    "interactive",
    "d3",
    "geojson"
  ],
  "license": "MIT"
}
